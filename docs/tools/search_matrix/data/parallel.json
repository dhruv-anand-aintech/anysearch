  },
  "snippet": {
    "support": "full",
    "source_url": "https://docs.parallel.ai/search/modes",
    "comment": "Short description field returned with each result."
  },
  "domains": {
    "support": "full",
    "source_url": "https://docs.parallel.ai/search/advanced-search-settings",
    "comment": "`advanced_settings.source_policy.include_domains` / `exclude_domains` (use sparingly)."
  },
  "country": {
    "support": "full",
    "source_url": "https://docs.parallel.ai/search/advanced-search-settings",
    "comment": "`advanced_settings.location` \u2014 ISO 3166-1 alpha-2 (subset of countries)."
  },
  "language": {
    "support": "none",
    "source_url": "https://docs.parallel.ai/search/modes",
    "comment": "Language"
  },
  "date": {
    "support": "full",
    "source_url": "https://docs.parallel.ai/search/advanced-search-settings",
