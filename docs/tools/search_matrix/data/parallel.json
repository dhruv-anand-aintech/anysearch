  },
  "safe_search": {
    "support": "none",
    "source_url": "https://docs.parallel.ai/search/modes",
    "comment": "Safe search"
  },
  "answer": {
    "support": "none",
    "source_url": "https://docs.parallel.ai/search/modes",
    "comment": "AI answer"
  },
  "content": {
    "support": "full",
    "source_url": "https://docs.parallel.ai/api-reference/search/search",
