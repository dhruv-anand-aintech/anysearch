{
  "name": "Searchapi",
  "links": {
    "docs": "https://www.searchapi.io/docs/google",
    "github": "https://github.com/dhruv-anand-aintech/anysearch",
    "website": "https://www.searchapi.io",
    "slug": "searchapi"
  },
  "env_keys": {
    "value": "SEARCHAPI_API_KEY, SEARCHAPI_KEY",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "API keys and configuration variables documented by the provider."
  },
  "python_extra": {
    "value": "\u2014 (REST only)",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "HTTP API only; no required vendor Python SDK."
  },
  "requires_key": {
    "support": "full",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "Valid API key required for every request."
  },
  "snippet": {
    "support": "full",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "Short description field returned with each result."
  },
  "domains": {
    "support": "none",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "Domain filters"
  },
  "country": {
    "support": "full",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "`gl` parameter on Google engine requests."
  },
  "language": {
    "support": "full",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "`hl` \u2014 language of the SERP."
  },
  "date": {
    "support": "none",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "Published date range"
  },
  "safe_search": {
    "support": "none",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "Safe search"
  },
  "answer": {
    "support": "partial",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "Featured snippets / answer box when returned by the engine."
  },
  "content": {
    "support": "none",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "Full page text"
  },
  "summary": {
    "support": "none",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "AI per-result summary"
  },
  "highlights": {
    "support": "none",
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "Query highlights"
  },
  "news": {
    "support": "full",
    "source_url": "https://www.searchapi.io/docs/google-news",
    "comment": "Use the Google News engine for news results."
  },
  "mode": {
    "values": [
      "balanced"
    ],
    "source_url": "https://www.searchapi.io/docs/google",
    "comment": "Google engine wrapper: single SERP depth per request (no native fast/deep tier)."
  },
  "notes": ""
}
