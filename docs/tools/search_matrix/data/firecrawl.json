  "language": {
    "support": "none",
    "source_url": "https://docs.firecrawl.dev/api-reference/endpoint/search",
    "comment": "Language"
  },
  "date": {
    "support": "none",
    "source_url": "https://docs.firecrawl.dev/api-reference/endpoint/search",
    "comment": "Published date range"
  },
  "safe_search": {
    "support": "none",
    "source_url": "https://docs.firecrawl.dev/api-reference/endpoint/search",
    "comment": "Safe search"
  },
  "answer": {
    "support": "none",
    "source_url": "https://docs.firecrawl.dev/api-reference/endpoint/search",
    "comment": "AI answer"
