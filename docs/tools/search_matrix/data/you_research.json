  },
  "domains": {
    "support": "partial",
    "source_url": "https://you.com/docs/research/overview",
    "comment": "`source_control.include_domains` / `exclude_domains` / `boost_domains` (beta)."
  },
  "country": {
    "support": "partial",
    "source_url": "https://you.com/docs/research/overview",
    "comment": "`source_control.country` \u2014 ISO 3166-1 alpha-2."
  },
  "language": {
    "support": "none",
    "source_url": "https://you.com/docs/research/overview",
