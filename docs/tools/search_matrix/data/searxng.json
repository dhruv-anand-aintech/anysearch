{
  "name": "SearXNG",
  "links": {
    "docs": "https://docs.searxng.org/dev/search_api.html",
    "github": "https://github.com/dhruv-anand-aintech/anysearch",
    "website": "https://docs.searxng.org",
    "slug": "searxng"
  },
  "env_keys": {
    "value": "SEARXNG_API_KEY",
    "source_url": "https://docs.searxng.org/admin/settings/settings_search/",
    "comment": "API keys and configuration variables documented by the provider."
  },
  "python_extra": {
    "value": "\u2014 (REST only)",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "HTTP API only; no required vendor Python SDK."
  },
  "requires_key": {
    "support": "none",
    "source_url": "https://docs.searxng.org/admin/settings/settings_search/",
    "comment": "No API key required."
  },
  "snippet": {
    "support": "full",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "Short description field returned with each result."
  },
  "domains": {
    "support": "none",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "Domain filters"
  },
  "country": {
    "support": "none",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "Country (gl)"
  },
  "language": {
    "support": "full",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "`language` query parameter (instance default if omitted)."
  },
  "date": {
    "support": "none",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "Published date range"
  },
  "safe_search": {
    "support": "full",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "`safesearch` 0=off, 1=moderate, 2=strict."
  },
  "answer": {
    "support": "full",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "Instant answers in the `answers` array when engines provide them."
  },
  "content": {
    "support": "none",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "Full page text"
  },
  "summary": {
    "support": "none",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "AI per-result summary"
  },
  "highlights": {
    "support": "none",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "Query highlights"
  },
  "news": {
    "support": "none",
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "News search type"
  },
  "mode": {
    "values": [
      "balanced"
    ],
    "source_url": "https://docs.searxng.org/dev/search_api.html",
    "comment": "Meta-search JSON API: result richness depends on configured engines, not a global depth flag. Matrix `balanced` = default instance search."
  },
  "notes": "No API key required (keyless fallback)."
}
