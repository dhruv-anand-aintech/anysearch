  "domains": {
    "support": "none",
    "source_url": "https://ai.google.dev/gemini-api/docs/google-search",
    "comment": "Domain filters"
  },
  "country": {
    "support": "none",
    "source_url": "https://ai.google.dev/gemini-api/docs/google-search",
    "comment": "Country (gl)"
