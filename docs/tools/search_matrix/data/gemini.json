  "language": {
    "support": "none",
    "source_url": "https://ai.google.dev/gemini-api/docs/google-search",
    "comment": "Language"
  },
  "date": {
    "support": "none",
    "source_url": "https://ai.google.dev/gemini-api/docs/google-search",
    "comment": "Published date range"
  },
  "safe_search": {
    "support": "none",
    "source_url": "https://ai.google.dev/gemini-api/docs/google-search",
