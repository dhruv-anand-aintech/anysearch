{
  "name": "Linkup",
  "links": {
    "docs": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "github": "https://github.com/dhruv-anand-aintech/anysearch",
    "website": "https://www.linkup.so",
    "slug": "linkup"
  },
  "env_keys": {
    "value": "LINKUP_API_KEY",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/reference",
    "comment": "API keys and configuration variables documented by the provider."
  },
  "python_extra": {
    "value": "linkup-sdk",
    "source_url": "https://docs.linkup.so/pages/sdk/python/python",
    "comment": "Optional PyPI package: linkup-sdk (install via anysearch-sdk extra `linkup`)."
  },
  "requires_key": {
    "support": "full",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/reference",
    "comment": "Valid API key required for every request."
  },
  "snippet": {
    "support": "full",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "comment": "Short description field returned with each result."
  },
  "domains": {
    "support": "full",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/reference",
    "comment": "`includeDomains` / `excludeDomains` arrays on POST /v1/search."
  },
  "country": {
    "support": "none",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "comment": "Country (gl)"
  },
  "language": {
    "support": "none",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "comment": "Language"
  },
  "date": {
    "support": "full",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/reference",
    "comment": "`fromDate` / `toDate` (YYYY-MM-DD) filter sources by publication date."
  },
  "safe_search": {
    "support": "none",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "comment": "Safe search"
  },
  "answer": {
    "support": "full",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "comment": "`outputType`: `sourcedAnswer` returns a cited natural-language answer."
  },
  "content": {
    "support": "full",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "comment": "`outputType`: `searchResults` with page content in standard/deep depths."
  },
  "summary": {
    "support": "none",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "comment": "AI per-result summary"
  },
  "highlights": {
    "support": "none",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "comment": "Query highlights"
  },
  "news": {
    "support": "none",
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "comment": "News search type"
  },
  "mode": {
    "values": [
      "fast",
      "balanced",
      "deep"
    ],
    "source_url": "https://docs.linkup.so/pages/documentation/endpoints/search/overview",
    "comment": "Native `depth`: `fast`, `standard` (balanced), or `deep` (multi-iteration agentic search-and-scrape). Cited synthesis uses `outputType=sourcedAnswer` (`answer=true` in anysearch), including at `deep` depth. anysearch: fast/balanced/deep\u2192matching depth."
  },
  "pricing_per_1k": {
    "value": "fast: \u20ac5; balanced/standard: \u20ac5; deep: \u20ac50",
    "source_url": "https://linkup-api.readme.io/reference/credits",
    "comment": "Fast and standard cost one credit/call; deep costs ten credits/call. Fast docs list \u20ac0.005/call."
  },
  "notes": "Native SDK package: linkup-sdk."
}
