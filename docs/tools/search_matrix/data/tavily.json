{
  "name": "Tavily",
  "links": {
    "docs": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "github": "https://github.com/dhruv-anand-aintech/anysearch",
    "website": "https://tavily.com",
    "slug": "tavily"
  },
  "env_keys": {
    "value": "TAVILY_API_KEY",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "API keys and configuration variables documented by the provider."
  },
  "python_extra": {
    "value": "tavily-python",
    "source_url": "https://pypi.org/project/tavily-python/",
    "comment": "Optional PyPI package: tavily-python (install via anysearch-sdk extra `tavily`)."
  },
  "requires_key": {
    "support": "full",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "Valid API key required for every request."
  },
  "snippet": {
    "support": "full",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "Short description field returned with each result."
  },
  "domains": {
    "support": "full",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "`include_domains` / `exclude_domains` (max 300 domains)."
  },
  "country": {
    "support": "full",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "`country` (topic `general` only) \u2014 ISO country name."
  },
  "language": {
    "support": "none",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "Language"
  },
  "date": {
    "support": "full",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "`start_date` / `end_date` or `time_range` (`day`, `week`, `month`, `year`)."
  },
  "safe_search": {
    "support": "none",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "Safe search"
  },
  "answer": {
    "support": "full",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "`include_answer`: `basic` or `advanced` LLM answer from results."
  },
  "content": {
    "support": "full",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "`include_raw_content` returns raw page text per source."
  },
  "summary": {
    "support": "none",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "AI per-result summary"
  },
  "highlights": {
    "support": "none",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "Query highlights"
  },
  "news": {
    "support": "full",
    "source_url": "https://docs.tavily.com/documentation/api-reference/endpoint/search",
    "comment": "`topic`: `news` (or `general` with news-oriented query)."
  },
  "mode": {
    "values": [
      "fast",
      "balanced",
      "deep"
    ],
    "source_url": "https://docs.tavily.com/documentation/best-practices/best-practices-search",
    "comment": "Native `search_depth`: `ultra-fast`, `fast`, `basic` (balanced default), `advanced` (highest relevance, 2 credits). anysearch: fast\u2192fast, balanced\u2192basic, deep\u2192advanced."
  },
  "notes": "Native SDK package: tavily-python."
}
