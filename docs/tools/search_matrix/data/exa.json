{
  "name": "Exa",
  "links": {
    "docs": "https://exa.ai/docs/reference/search",
    "github": "https://github.com/dhruv-anand-aintech/anysearch",
    "website": "https://exa.ai",
    "slug": "exa"
  },
  "env_keys": {
    "value": "EXA_API_KEY",
    "source_url": "https://exa.ai/docs/reference/quickstart",
    "comment": "API keys and configuration variables documented by the provider."
  },
  "python_extra": {
    "value": "exa-py",
    "source_url": "https://pypi.org/project/exa-py/",
    "comment": "Optional PyPI package: exa-py (install via anysearch-sdk extra `exa`)."
  },
  "requires_key": {
    "support": "full",
    "source_url": "https://exa.ai/docs/reference/quickstart",
    "comment": "Valid API key required for every request."
  },
  "snippet": {
    "support": "full",
    "source_url": "https://exa.ai/docs/reference/search",
    "comment": "Short description field returned with each result."
  },
  "domains": {
    "support": "full",
    "source_url": "https://exa.ai/docs/reference/search",
    "comment": "`includeDomains` / `excludeDomains` on POST /search."
  },
  "country": {
    "support": "full",
    "source_url": "https://exa.ai/docs/reference/search",
    "comment": "`userLocation` (ISO country code) biases results."
  },
  "language": {
    "support": "none",
    "source_url": "https://exa.ai/docs/reference/search",
    "comment": "Language"
  },
  "date": {
    "support": "full",
    "source_url": "https://exa.ai/docs/reference/search",
    "comment": "`startPublishedDate` / `endPublishedDate` (ISO dates)."
  },
  "safe_search": {
    "support": "full",
    "source_url": "https://exa.ai/docs/reference/search",
    "comment": "`moderation: true` enables content filtering."
  },
  "answer": {
    "support": "none",
    "source_url": "https://exa.ai/docs/reference/search",
    "comment": "AI answer"
  },
  "content": {
    "support": "full",
    "source_url": "https://exa.ai/docs/reference/search",
    "comment": "`contents.text` (or highlights) in the request body."
  },
  "summary": {
    "support": "full",
    "source_url": "https://exa.ai/docs/reference/search",
    "comment": "`contents.summary` returns an AI summary per result."
  },
  "highlights": {
    "support": "full",
    "source_url": "https://exa.ai/docs/reference/search-best-practices",
    "comment": "`contents.highlights` \u2014 query-relevant excerpts (~10\u00d7 fewer tokens than full text)."
  },
  "news": {
    "support": "full",
    "source_url": "https://exa.ai/docs/reference/search",
    "comment": "`category: news` or `type` tuned for news-style retrieval."
  },
  "mode": {
    "values": [
      "fast",
      "balanced",
      "deep"
    ],
    "source_url": "https://exa.ai/docs/reference/search-api-guide",
    "comment": "POST /search `type`: `instant`/`fast` (latency), `auto` (balanced), `deep` / `deep-lite` / `deep-reasoning` (agentic multi-source synthesis; optional `output_schema`). anysearch: fast\u2192fast, balanced\u2192auto, deep\u2192deep."
  },
  "pricing_per_1k": {
    "value": "fast/balanced: $7; deep: $12; deep reasoning: $15",
    "source_url": "https://exa.ai/pricing",
    "comment": "Per 1K requests with up to 10 results; summaries and additional results are billed separately."
  },
  "notes": "Native SDK package: exa-py."
}
