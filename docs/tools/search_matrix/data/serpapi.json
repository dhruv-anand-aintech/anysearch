{
  "name": "SerpApi",
  "links": {
    "docs": "https://serpapi.com/search-api",
    "github": "https://github.com/dhruv-anand-aintech/anysearch",
    "website": "https://serpapi.com",
    "slug": "serpapi"
  },
  "env_keys": {
    "value": "SERPAPI_API_KEY, SERPAPI_KEY",
    "source_url": "https://serpapi.com/search-api",
    "comment": "API keys and configuration variables documented by the provider."
  },
  "python_extra": {
    "value": "google-search-results",
    "source_url": "https://pypi.org/project/google-search-results/",
    "comment": "Optional PyPI package: google-search-results (install via anysearch-sdk extra `serpapi`)."
  },
  "requires_key": {
    "support": "full",
    "source_url": "https://serpapi.com/search-api",
    "comment": "Valid API key required for every request."
  },
  "snippet": {
    "support": "full",
    "source_url": "https://serpapi.com/search-api",
    "comment": "Short description field returned with each result."
  },
  "domains": {
    "support": "none",
    "source_url": "https://serpapi.com/search-api",
    "comment": "Domain filters"
  },
  "country": {
    "support": "full",
    "source_url": "https://serpapi.com/search-api",
    "comment": "`gl` \u2014 country code."
  },
  "language": {
    "support": "full",
    "source_url": "https://serpapi.com/search-api",
    "comment": "`hl` \u2014 language code."
  },
  "date": {
    "support": "none",
    "source_url": "https://serpapi.com/search-api",
    "comment": "Published date range"
  },
  "safe_search": {
    "support": "full",
    "source_url": "https://serpapi.com/search-api",
    "comment": "`safe` \u2014 active or off."
  },
  "answer": {
    "support": "partial",
    "source_url": "https://serpapi.com/search-api",
    "comment": "Answer box fields when present in the engine JSON."
  },
  "content": {
    "support": "none",
    "source_url": "https://serpapi.com/search-api",
    "comment": "Full page text"
  },
  "summary": {
    "support": "none",
    "source_url": "https://serpapi.com/search-api",
    "comment": "AI per-result summary"
  },
  "highlights": {
    "support": "none",
    "source_url": "https://serpapi.com/search-api",
    "comment": "Query highlights"
  },
  "news": {
    "support": "full",
    "source_url": "https://serpapi.com/search-api",
    "comment": "`engine=google_news` (or other news engines)."
  },
  "mode": {
    "values": [
      "balanced"
    ],
    "source_url": "https://serpapi.com/search-api",
    "comment": "Aggregated Google engine API: no latency/depth parameter on the search call. Matrix `balanced` = default engine JSON response."
  },
  "notes": "Native SDK package: google-search-results."
}
